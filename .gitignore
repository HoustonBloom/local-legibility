# Local Brain · gitignore

# OS
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo

# Editors
.idea/
.vscode/
*.sublime-workspace
*.sublime-project

# Node (in case downstream users add tooling)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.pnpm-debug.log*

# Python (in case downstream users add scripts)
__pycache__/
*.py[cod]
.venv/
venv/

# Build manifest (regenerated by build-window-frames.mjs on every build;
# transient artifact, no reason to commit)
01_tools/00_overview/BUILD-MANIFEST.yaml

# User-generated outputs (downstream users will fill these in)
00_inbox/*
!00_inbox/README.md
!00_inbox/.gitkeep
03_cuts/*
!03_cuts/README.md
!03_cuts/00_public/
03_cuts/00_public/*
!03_cuts/00_public/README.md
!03_cuts/00_public/00_assets/
03_cuts/00_public/00_assets/*
!03_cuts/00_public/00_assets/README.md

# Activity log (the user's own log, not packet content)
02_activity/*.md
!02_activity/README.md
!02_activity/_template.md

# Contacts (downstream users add their own)
01_tools/05_contacts/*.md
!01_tools/05_contacts/README.md
!01_tools/05_contacts/_template.md

# Local AI / dev server scratch
.cache/
.tmp/
tmp/

# Environment
.env
.env.local
.env.*.local
